						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Guide Cleopatra\",\n  \"email\": \"cleopatra.guide@example.com\",\n  \"password\": \"guidepass123\",\n  \"role\": \"Guide\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users"
							]
						},
						"description": "Create a new user. Requires Admin role."
					},
					"response": []
				},
				{
